<Window
    x:Class="WinAPX.Gui.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WinAPX.Gui"
    Title="WinAPX">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
    <Grid Padding="24,20,24,16"
          MinHeight="440"
          RowDefinitions="Auto,*,Auto"
          ColumnDefinitions="*,Auto,Auto">

        <!-- Env name input, mode toggles, & run button -->

        <Grid Grid.Row="0" Grid.Column="0" Margin="0,0,10,0">
            <TextBox x:Name="envNameBox"
                     PlaceholderText="Environment name"
                     VerticalAlignment="Center"/>
            <ComboBox x:Name="envNameCombo"
                      Visibility="Collapsed"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"
                      PlaceholderText="Select environment"/>
            <ProgressRing x:Name="envLoadingRing"
                          Visibility="Collapsed"
                          IsActive="False"
                          Width="20" Height="20"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
        </Grid>

        <StackPanel Grid.Row="0" Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="4"
                    Margin="0,0,10,0"
                    VerticalAlignment="Center">
            <ToggleButton x:Name="modeEnterToggle"
                          IsChecked="True"
                          Width="36" Height="36" Padding="0"
                          Checked="ModeToggle_Checked"
                          Unchecked="ModeToggle_Unchecked"
                          ToolTipService.ToolTip="Manage">
                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8A9;" FontSize="15"/>
            </ToggleButton>
            <ToggleButton x:Name="modeCreateToggle"
                          Width="36" Height="36" Padding="0"
                          Checked="ModeToggle_Checked"
                          Unchecked="ModeToggle_Unchecked"
                          ToolTipService.ToolTip="Create">
                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE710;" FontSize="15"/>
            </ToggleButton>
            <ToggleButton x:Name="modeDeleteToggle"
                          Width="36" Height="36" Padding="0"
                          Checked="ModeToggle_Checked"
                          Unchecked="ModeToggle_Unchecked"
                          ToolTipService.ToolTip="Delete">
                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE74D;" FontSize="15"/>
            </ToggleButton>
        </StackPanel>

        <Button Grid.Row="0" Grid.Column="2"
                x:Name="runButton"
                MinWidth="120"
                VerticalAlignment="Center"
                Style="{StaticResource AccentButtonStyle}"
                Content="Enter"
                Click="Run_Click"/>

        <!-- options panel (row 1 = main content area) -->
        <Grid Grid.Row="1" Grid.ColumnSpan="3" Margin="0,16,0,0">

            <!-- Manage mode -->
            <StackPanel x:Name="manageOptions" Spacing="12">
                <CheckBox x:Name="enterDirCheck" Content="Start in custom folder"/>

                <!-- Apps section header -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,12,0,0">
                    <TextBlock Grid.Column="0" Text="Exported apps" FontSize="16" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Export new app…" Click="ExportApp_Click"
                            Style="{StaticResource AccentButtonStyle}"/>
                </Grid>

                <!-- Apps list -->
                <Border CornerRadius="8" BorderBrush="#33FFFFFF" BorderThickness="1" MinHeight="200">
                    <ListView x:Name="appsList"
                              ItemsSource="{x:Bind ExportedApps, Mode=OneWay}"
                              SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:ExportedAppVm">
                                <Grid ColumnDefinitions="32,*,Auto,Auto" Padding="8" ColumnSpacing="12">
                                    <Image Grid.Column="0" Width="24" Height="24" Source="{x:Bind IconSource}"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind DisplayName}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{x:Bind Command}" Opacity="0.6" FontSize="12"/>
                                    </StackPanel>
                                    <Button Grid.Column="2" Click="LaunchApp_Click" Tag="{x:Bind Id}"
                                            ToolTipService.ToolTip="Launch" Margin="0,0,4,0">
                                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE768;" FontSize="14"/>
                                    </Button>
                                    <Button Grid.Column="3" Click="DeleteApp_Click" Tag="{x:Bind Id}"
                                            ToolTipService.ToolTip="Remove">
                                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE74D;" FontSize="14"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>
            </StackPanel>

            <!-- Create mode -->
            <StackPanel x:Name="createOptions" Visibility="Collapsed"
                        Orientation="Horizontal" Spacing="16" VerticalAlignment="Top">
                <ComboBox x:Name="distroCombo"
                          SelectedIndex="0"
                          MinWidth="120">
                    <ComboBoxItem Content="ubuntu"/>
                    <ComboBoxItem Content="arch"/>
                </ComboBox>
                <CheckBox x:Name="createInstallDirCheck"
                          Content="Custom install folder"
                          VerticalAlignment="Center"/>
                <CheckBox x:Name="createWkdirCheck"
                          Content="Default working directory"
                          VerticalAlignment="Center"/>
                <CheckBox x:Name="createRecommendedPkgsCheck"
                          Content="Install recommended packages"
                          VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Delete mode -->
            <StackPanel x:Name="deleteOptions" Visibility="Collapsed">
                <CheckBox x:Name="keepFilesCheck" Content="Keep files on disk"/>
            </StackPanel>

        </Grid>

        <!-- footer: loading indicator + env-level actions -->
        <Grid Grid.Row="2" Grid.ColumnSpan="3" Margin="0,12,0,0">
            <ProgressRing x:Name="commandLoadingRing"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Center"
                          Width="20" Height="20"
                          IsActive="False"
                          Visibility="Collapsed"/>
            <StackPanel Orientation="Horizontal" Spacing="8"
                        HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button x:Name="importEnvButton"
                        Content="Import environment…"
                        Visibility="Collapsed"
                        Click="ImportEnv_Click"/>
                <Button x:Name="exportEnvButton"
                        Content="Export environment…"
                        Click="ExportEnv_Click"/>
            </StackPanel>
        </Grid>

    </Grid>
    </ScrollViewer>
</Window>
