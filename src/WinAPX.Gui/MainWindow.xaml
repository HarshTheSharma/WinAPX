<Window
    x:Class="WinAPX.Gui.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="WinAPX">

    <Grid Padding="20" RowDefinitions="Auto,Auto,Auto,*" ColumnDefinitions="*,Auto,Auto">

        <!-- Row 0: Name + Mode icon toggles + Action button -->
        <TextBox Grid.Row="0" Grid.Column="0"
                 x:Name="envNameBox"
                 Margin="0,0,10,0"
                 PlaceholderText="Environment name"
                 VerticalAlignment="Center" />

        <StackPanel Grid.Row="0" Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="4"
                    Margin="0,0,10,0"
                    VerticalAlignment="Center">
            <ToggleButton x:Name="modeEnterToggle"
                          IsChecked="True"
                          Width="36" Height="36" Padding="0"
                          Checked="ModeToggle_Checked"
                          Unchecked="ModeToggle_Unchecked"
                          ToolTipService.ToolTip="Enter">
                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8A9;" FontSize="15"/>
            </ToggleButton>
            <ToggleButton x:Name="modeCreateToggle"
                          Width="36" Height="36" Padding="0"
                          Checked="ModeToggle_Checked"
                          Unchecked="ModeToggle_Unchecked"
                          ToolTipService.ToolTip="Create">
                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE710;" FontSize="15"/>
            </ToggleButton>
            <ToggleButton x:Name="modeDeleteToggle"
                          Width="36" Height="36" Padding="0"
                          Checked="ModeToggle_Checked"
                          Unchecked="ModeToggle_Unchecked"
                          ToolTipService.ToolTip="Delete">
                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE74D;" FontSize="15"/>
            </ToggleButton>
        </StackPanel>

        <Button Grid.Row="0" Grid.Column="2"
                x:Name="runButton"
                MinWidth="120"
                VerticalAlignment="Center"
                Content="Enter"
                Click="Run_Click" />

        <!-- Row 1: Mode-specific options -->
        <Grid Grid.Row="1" Grid.ColumnSpan="3" Margin="0,14,0,0">

            <!-- Enter options -->
            <StackPanel x:Name="enterOptions" Spacing="10">
                <CheckBox x:Name="enterDirCheck" Content="Start in a custom folder"/>
            </StackPanel>

            <!-- Create options -->
            <Grid x:Name="createOptions" Visibility="Collapsed"
                  ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Distro"
                           VerticalAlignment="Center"
                           Margin="12,0,12,0"/>
                <ComboBox Grid.Row="0" Grid.Column="1"
                          x:Name="distroCombo"
                          SelectedIndex="0"
                          HorizontalAlignment="Left"
                          MinWidth="150">
                    <ComboBoxItem Content="ubuntu"/>
                    <ComboBoxItem Content="arch"/>
                </ComboBox>
                <CheckBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                          x:Name="createInstallDirCheck"
                          Content="Choose custom install folder"/>
                <CheckBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                          x:Name="createWkdirCheck"
                          Content="Use a default working directory"/>
            </Grid>

            <!-- Delete options -->
            <StackPanel x:Name="deleteOptions" Visibility="Collapsed">
                <CheckBox x:Name="keepFilesCheck" Content="Keep files on disk"/>
            </StackPanel>

        </Grid>

        <!-- Row 2: List + Clear -->
        <StackPanel Grid.Row="2" Grid.ColumnSpan="3"
                    Orientation="Horizontal"
                    Spacing="12"
                    Margin="0,18,0,0">
            <Button x:Name="listButton" MinWidth="100" Content="List"  Click="List_Click"/>
            <Button                     MinWidth="100" Content="Clear" Click="Clear_Click"/>
        </StackPanel>

        <!-- Row 3: Output -->
        <Border Grid.Row="3" Grid.ColumnSpan="3"
                Margin="0,18,0,0"
                CornerRadius="8"
                Background="#FF2A2A2A"
                Padding="14">
            <ListView ItemsSource="{x:Bind logLines, Mode=OneWay}" />
        </Border>

    </Grid>
</Window>
