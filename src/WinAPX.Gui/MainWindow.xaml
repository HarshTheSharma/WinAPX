<Window
    x:Class="WinAPX.Gui.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="WinAPX">

    <Grid Padding="24,20,24,16"
          RowDefinitions="Auto,Auto,*,Auto"
          ColumnDefinitions="*,Auto,Auto">

        <!-- Env name input, mode toggles, & run button -->

        <Grid Grid.Row="0" Grid.Column="0" Margin="0,0,10,0">
            <TextBox x:Name="envNameBox"
                     PlaceholderText="Environment name"
                     VerticalAlignment="Center"/>
            <ComboBox x:Name="envNameCombo"
                      Visibility="Collapsed"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"
                      PlaceholderText="Select environment"/>
            <ProgressRing x:Name="envLoadingRing"
                          Visibility="Collapsed"
                          IsActive="False"
                          Width="20" Height="20"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
        </Grid>

        <StackPanel Grid.Row="0" Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="4"
                    Margin="0,0,10,0"
                    VerticalAlignment="Center">
            <ToggleButton x:Name="modeEnterToggle"
                          IsChecked="True"
                          Width="36" Height="36" Padding="0"
                          Checked="ModeToggle_Checked"
                          Unchecked="ModeToggle_Unchecked"
                          ToolTipService.ToolTip="Enter">
                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8A9;" FontSize="15"/>
            </ToggleButton>
            <ToggleButton x:Name="modeCreateToggle"
                          Width="36" Height="36" Padding="0"
                          Checked="ModeToggle_Checked"
                          Unchecked="ModeToggle_Unchecked"
                          ToolTipService.ToolTip="Create">
                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE710;" FontSize="15"/>
            </ToggleButton>
            <ToggleButton x:Name="modeDeleteToggle"
                          Width="36" Height="36" Padding="0"
                          Checked="ModeToggle_Checked"
                          Unchecked="ModeToggle_Unchecked"
                          ToolTipService.ToolTip="Delete">
                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE74D;" FontSize="15"/>
            </ToggleButton>
        </StackPanel>

        <Button Grid.Row="0" Grid.Column="2"
                x:Name="runButton"
                MinWidth="120"
                VerticalAlignment="Center"
                Style="{StaticResource AccentButtonStyle}"
                Content="Enter"
                Click="Run_Click"/>

        <!-- advanced options -->
        <Grid Grid.Row="1" Grid.ColumnSpan="3" Margin="0,16,0,0">

            <StackPanel x:Name="enterOptions" Spacing="10">
                <CheckBox x:Name="enterDirCheck" Content="Start in a custom folder"/>
            </StackPanel>

            <StackPanel x:Name="createOptions" Visibility="Collapsed"
                        Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                <ComboBox x:Name="distroCombo"
                          SelectedIndex="0"
                          MinWidth="120">
                    <ComboBoxItem Content="ubuntu"/>
                    <ComboBoxItem Content="arch"/>
                </ComboBox>
                <CheckBox x:Name="createInstallDirCheck"
                          Content="Custom install folder"
                          VerticalAlignment="Center"/>
                <CheckBox x:Name="createWkdirCheck"
                          Content="Default working directory"
                          VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel x:Name="deleteOptions" Visibility="Collapsed">
                <CheckBox x:Name="keepFilesCheck" Content="Keep files on disk"/>
            </StackPanel>

        </Grid>

        <!-- console -->
        <Grid x:Name="advancedPanel"
              Grid.Row="2" Grid.ColumnSpan="3"
              Visibility="Collapsed"
              Margin="0,20,0,0"
              RowDefinitions="Auto,*">
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                <Button x:Name="listButton" MinWidth="80" Content="List" Click="List_Click"/>
                <Button MinWidth="80" Content="Clear" Click="Clear_Click"/>
            </StackPanel>
            <Border Grid.Row="1"
                    CornerRadius="8"
                    Background="#FF1E1E1E"
                    BorderBrush="#33FFFFFF"
                    BorderThickness="1"
                    Padding="12">
                <ListView ItemsSource="{x:Bind logLines, Mode=OneWay}"
                          FontFamily="Cascadia Code, Consolas, monospace"
                          FontSize="12"/>
            </Border>
        </Grid>

        <!-- loading indicator & settings cog -->
        <Grid Grid.Row="3" Grid.ColumnSpan="3" Margin="0,12,0,0">
            <ProgressRing x:Name="commandLoadingRing"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Center"
                          Width="20" Height="20"
                          IsActive="False"
                          Visibility="Collapsed"/>
            <Button HorizontalAlignment="Right"
                    Width="32" Height="32" Padding="0"
                    ToolTipService.ToolTip="View options">
                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE713;" FontSize="14"/>
                <Button.Flyout>
                    <MenuFlyout Placement="TopEdgeAlignedRight">
                        <ToggleMenuFlyoutItem x:Name="showConsoleMenuItem"
                                              Text="Show console"
                                              Click="ShowConsole_Click"/>
                    </MenuFlyout>
                </Button.Flyout>
            </Button>
        </Grid>

    </Grid>
</Window>
